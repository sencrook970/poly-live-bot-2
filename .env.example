# ===========================================
# POLYMARKET BOT — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- WALLET ---
# Your Ethereum private key (the one that controls your Polymarket account)
# NEVER share this. NEVER commit .env to git.
# How to get it: Export from MetaMask or your wallet app
PRIVATE_KEY=your_private_key_here

# Your Polymarket profile address (where your USDC lives on Polymarket)
# This is NOT your wallet address — it's the proxy address Polymarket creates for you
# How to find it: Go to polymarket.com → Settings → your deposit address
FUNDER_ADDRESS=your_polymarket_profile_address_here

# Signature type: 0 = MetaMask/hardware wallet, 1 = Email/Magic login
SIGNATURE_TYPE=0

# --- API KEYS (auto-generated on first run) ---
# These get created automatically when you run `npm run setup-keys`
# After running setup, paste the output values here
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# --- AI PREDICTION (optional — needed for AI strategy) ---
# Works with OpenAI OR OpenRouter. Pick one:
#
# Option A: OpenAI
#   OPENAI_API_KEY=sk-your-openai-key
#   AI_MODEL=gpt-4o-mini
#
# Option B: OpenRouter (recommended — cheaper, more model choices)
#   OPENAI_API_KEY=sk-or-your-openrouter-key
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   AI_MODEL=google/gemini-2.0-flash-001
#
OPENAI_API_KEY=your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=google/gemini-2.0-flash-001

# --- TRADING SETTINGS ---
# Start in paper trade mode (no real money). Set to "false" when ready to go live.
PAPER_TRADE=true

# Maximum amount of USDC the bot can risk in a single day
DAILY_LOSS_LIMIT=50

# Maximum USDC per single trade
MAX_TRADE_SIZE=20

# Minimum edge (%) before the bot will place a trade
# Example: 3 means the bot needs at least 5% edge to trade
MIN_EDGE_PERCENT=3

# How often to scan for opportunities (in seconds)
SCAN_INTERVAL_SECONDS=30

# --- STRATEGY TOGGLES ---
# Turn individual strategies on/off (true/false)
STRATEGY_ARBITRAGE=true
STRATEGY_MISPRICING=true
STRATEGY_AI_PREDICTION=true
